BASE_URL=https://kerebyudlejning.dk
RENTALS_API_BASE_URL=https://api.jorato.com
RENTALS_API_KEY=EXAMPLE_KEY
EMAIL_TO=your-email@example.com
EMAIL_FROM=alerts@example.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_AUTH_METHOD=password
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_key
# Brug nedenstående ved OAuth2 (fx Microsoft/Outlook med Modern Auth)
SMTP_OAUTH_CLIENT_ID=
SMTP_OAUTH_CLIENT_SECRET=
SMTP_OAUTH_REFRESH_TOKEN=
SMTP_OAUTH_TENANT_ID=common
SMTP_OAUTH_REDIRECT_URI=http://localhost
SMTP_OAUTH_SCOPE=offline_access https://outlook.office.com/SMTP.Send
# Valgfri override:
# SMTP_OAUTH_ACCESS_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
MAX_RENT=16000
MIN_ROOMS=3
CHECK_PATHS=/,/ledige-lejemaal,/udlejning,/lejligheder,/boliger
